// Allow users in the "sudo" group full control over NetworkManager.
// This is required for the AiHomeCloud backend to manage Wi-Fi connections,
// hotspot, and network toggles via nmcli without root privileges.
// Note: subject.local/active checks are omitted because the backend
// runs as a background service (not an interactive session).
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.freedesktop.NetworkManager.") === 0 &&
        (subject.isInGroup("sudo") || subject.isInGroup("netdev"))) {
        return polkit.Result.YES;
    }
});
